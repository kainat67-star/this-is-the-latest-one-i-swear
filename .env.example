# Supabase (Vite exposes only variables prefixed with VITE_)
# Copy to `.env` or `.env.local` and fill with your project values from:
# Supabase Dashboard → Project Settings → API
# No trailing slash (avoids broken /functions/v1 and /rest/v1 requests)
VITE_SUPABASE_URL=https://vhpovcagjelwelkeqqff.supabase.co
VITE_SUPABASE_ANON_KEY=

# Google Ads OAuth (Authorization code flow — Web application client in Google Cloud)
VITE_GOOGLE_CLIENT_ID=

# Google Ads callback uses Edge Function google-ads-auth: deploy with
# `supabase functions deploy google-ads-auth` and set secrets GOOGLE_CLIENT_ID,
# GOOGLE_CLIENT_SECRET, APP_URL (optional; callback sends redirect_uri).

# If you port this code to Next.js, use the same values with:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
~